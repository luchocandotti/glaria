  "editor.tokenColorCustomizations": {
    "textMateRules": [
      {
        "scope": ["comment", "comment.line", "comment.block", "punctuation.definition.comment"],
        "settings": { "foreground": "#4a4a46", "fontStyle": "italic" }
      },
      {
        "scope": ["string", "string.quoted", "string.template"],
        "settings": { "foreground": "#7aaa6a" }
      },
      {
        "scope": ["keyword", "keyword.control", "storage", "storage.type", "storage.modifier"],
        "settings": { "foreground": "#8099d4", "fontStyle": "" }
      },
      {
        "scope": ["constant.numeric", "constant.language", "constant.character"],
        "settings": { "foreground": "#c4943a" }
      },
      {
        "scope": ["entity.name.function", "support.function", "meta.function-call"],
        "settings": { "foreground": "#c8c6bc" }
      },
      {
        "scope": ["variable", "variable.other", "variable.parameter"],
        "settings": { "foreground": "#c8c6bc" }
      },
      {
        "scope": ["entity.name.type", "support.type", "support.class", "entity.name.class"],
        "settings": { "foreground": "#8099d4" }
      },
      {
        "scope": ["invalid", "invalid.illegal"],
        "settings": { "foreground": "#c45a5a" }
      },
      {
        "scope": ["punctuation", "meta.brace"],
        "settings": { "foreground": "#8c8a82" }
      }
    ]
  }
}